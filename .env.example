# GemmaClip environment example
#
# Copy this file to `.env`, fill in at least one provider credential, and
# keep the real `.env` file private. The production web container reads `.env`
# at runtime through docker-compose.web.yml or --env-file.

# -----------------------------------------------------------------------------
# Recommended routed Gemma setup
# -----------------------------------------------------------------------------

GEMMACLIP_PROVIDER=routed_gemma
GEMMACLIP_AUDIO_MODE=auto

# Add at least one provider credential. When both are configured, Fireworks is
# attempted first and Google is used for the supported fallback roles.
FIREWORKS_API_KEY=
GOOGLE_API_KEY=

# Supported credential aliases:
# GEMMA_API_KEY=
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Routed model roles
# -----------------------------------------------------------------------------

FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_GEMMA_VISUAL_MODEL=accounts/fireworks/models/gemma-4-26b-a4b-it
FIREWORKS_GEMMA_AUDIO_VISUAL_MODEL=accounts/fireworks/models/gemma-4-12b-unified-it
FIREWORKS_GEMMA_CAPTION_MODEL=accounts/fireworks/models/gemma-4-31b-it

# Optional AMD Cloud override for the audio-visual evidence role only. When
# both values are set, this replaces the Fireworks 12B audio-visual attempt.
# The current AMD deployment advertises model id `gemma-4-12b-it`.
AMD_GEMMA_AUDIO_VISUAL_API_KEY=
AMD_GEMMA_AUDIO_VISUAL_BASE_URL=
AMD_GEMMA_AUDIO_VISUAL_MODEL=gemma-4-12b-it

GOOGLE_GEMMA_VISUAL_MODEL=gemma-4-31b-it
# Reserved for explicit experimentation. The production Fireworks audio-visual
# fallback drops audio and sends frames only to GOOGLE_GEMMA_VISUAL_MODEL.
GOOGLE_GEMMA_AUDIO_VISUAL_MODEL=gemma-4-12b-unified-it
GOOGLE_GEMMA_CAPTION_MODEL=gemma-4-31b-it

GEMMA_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# Audio routing
# -----------------------------------------------------------------------------

GEMMACLIP_AUDIO_MAX_SECONDS=30
GEMMACLIP_AUDIO_SAMPLE_RATE=16000
GEMMACLIP_AUDIO_MIN_RMS=0.01
GEMMACLIP_AUDIO_MIN_REMAINING_SECONDS=170

# -----------------------------------------------------------------------------
# Routed generation settings
# -----------------------------------------------------------------------------

GEMMACLIP_ROUTED_EVIDENCE_TEMPERATURE=0.0
GEMMACLIP_ROUTED_CAPTION_TEMPERATURE=0.4
GEMMACLIP_ROUTED_REPAIR_TEMPERATURE=0.25
GEMMACLIP_ROUTED_SINGLE_CALL_TEMPERATURE=0.4
GEMMACLIP_DISABLE_VERIFIER=true

# -----------------------------------------------------------------------------
# Web demo runtime
# -----------------------------------------------------------------------------

GEMMACLIP_WEB_HOST=0.0.0.0
GEMMACLIP_WEB_PORT=8000
GEMMACLIP_WEB_RUNS_DIR=/data/runs
GEMMACLIP_WEB_RUN_TTL_SECONDS=86400
GEMMACLIP_WEB_MAX_UPLOAD_BYTES=209715200
GEMMACLIP_WEB_CORS_ORIGINS=

# Use `json` for one safe structured lifecycle event per line.
GEMMACLIP_LOG_FORMAT=json

# Only needed when building or running the frontend separately from FastAPI.
# VITE_GEMMACLIP_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Optional alternative provider modes
# -----------------------------------------------------------------------------

# Google-only:
# GEMMACLIP_PROVIDER=google
# GEMINI_MODEL=gemma-4-26b-a4b-it

# Generic Fireworks/OpenAI-compatible mode:
# GEMMACLIP_PROVIDER=fireworks
# GEMMA_BASE_URL=https://api.fireworks.ai/inference/v1
# GEMMA_MODEL=
# GEMMA_VISION_MODEL=accounts/fireworks/models/qwen3p7-plus
# GEMMA_TEXT_MODEL=accounts/fireworks/models/deepseek-v4-pro
# GEMMA_FALLBACK_MODELS=accounts/fireworks/models/kimi-k2p6
# GEMMA_USE_RESPONSE_FORMAT=false

# Fireworks judge mode:
# GEMMACLIP_PROVIDER=fireworks_judge
# FIREWORKS_VISION_MODEL=accounts/fireworks/models/minimax-m3
# FIREWORKS_FALLBACK_VISION_MODEL=accounts/fireworks/models/qwen3p7-plus

# OpenRouter mode:
# GEMMACLIP_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=

# Test-only controls. Keep disabled for real demo runs.
# GEMMACLIP_FORCE_PLACEHOLDER=false
# GEMMACLIP_FORCE_FALLBACK=false
